{
	"name": "directus-extension-pdf2img-operation",
	"description": "Directus operation extension used to convert a PDF from an URL to images and store them",
	"icon": "extension",
	"license": "MIT",
	"version": "1.1.1",
	"author": "Euryece Telecom",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-operation",
		"pdf2img"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "operation",
		"path": {
			"app": "dist/app.js",
			"api": "dist/api.js"
		},
		"source": {
			"app": "src/app.ts",
			"api": "src/api.ts"
		},
		"host": "^11.4.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "^17.1.1",
		"@types/node": "^22.13.10",
		"typescript": "^5.9.2",
		"vue": "^3.5.32"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euryecetelecom/directus-extension-pdf2img-operation.git"
	},
	"homepage": "https://github.com/euryecetelecom/directus-extension-pdf2img-operation",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"pdf2pic": "^3.2.0"
	}
}
